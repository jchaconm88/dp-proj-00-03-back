# Rol de aplicación (Terraform/Neon: app_user). No puede crear tablas.
DATABASE_URL=postgresql://app_user:password@host/dbname?sslmode=require
# Solo para `pnpm db:migrate`: rol owner de Neon (Connection string sin pooler, usuario por defecto del proyecto).
# DATABASE_URL_MIGRATE=postgresql://neondb_owner:password@host/dbname?sslmode=require
PAYLOAD_SECRET=your-secret-key-min-32-chars
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
# Orígenes extra (coma) si el CMS tiene dominio distinto al de Cloud Run, ej. https://cms.tudominio.com
# PAYLOAD_CSRF_ORIGINS=https://cms.tudominio.com
FIREBASE_STORAGE_BUCKET=dp-proj-00-03-storage
FIREBASE_PROJECT_ID=tu-proyecto-gcp
NODE_ENV=development
PORT=3000
RESEND_API_KEY=re_xxxxxxxxxxxx
TURNSTILE_SECRET_KEY=your-turnstile-secret
INTERNAL_API_TOKEN=your-internal-token
FRONTEND_WEBHOOK_URL=http://localhost:4321/api/webhooks/rebuild
FRONTEND_WEBHOOK_SECRET=your-webhook-secret
JWT_EXTERNAL_PROVIDERS=https://your-idp.com/.well-known/jwks.json
# Almacenamiento local de plantillas HTML (desarrollo)
TEMPLATE_STORAGE_ROOT=./storage/templates
# Publicación programada (Cloud Scheduler). Por defecto desactivado.
# PUBLISH_SCHEDULER_ENABLED=true
